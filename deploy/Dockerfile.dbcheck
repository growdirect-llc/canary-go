# deploy/Dockerfile.dbcheck
# Multi-stage build for the cmd/dbcheck Cloud SQL connectivity smoke-test service.
# Mirrors Dockerfile.identity / Dockerfile.hello pattern.
FROM golang:1.26.3-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /dbcheck ./cmd/dbcheck

FROM alpine:3.19
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /dbcheck /dbcheck
EXPOSE 8080
ENTRYPOINT ["/dbcheck"]
