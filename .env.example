# CanaryGo — env-var template.
#
# Copy to .env and fill in real values for local development. The
# gateway and identity services read these via internal/config.Load
# (which fatals on missing required values) plus direct os.Getenv
# calls in feature-specific paths. Production deployments source
# secrets from GCP Secret Manager (set SECRET_BACKEND=sm).
#
# Last reviewed: 2026-05-07 (Sprint 2 T-M / GRO-857).

# ─── Required for gateway boot (config.Load fatals if missing) ───

# DATABASE_URL — Postgres connection string for the canary_gcp database.
DATABASE_URL=postgres://growdirect:growdirect_dev@localhost:5432/canary_gcp?sslmode=disable

# VALKEY_URL — Redis-compatible client URL. DB 2 is canary.go's slot.
VALKEY_URL=redis://:valkey_dev@localhost:6379/2

# INTERNAL_SERVICE_SECRET — shared secret for gateway↔identity calls.
# Rotate independently of customer secrets.
INTERNAL_SERVICE_SECRET=dev-internal-secret

# SESSION_SECRET — HMAC key for the demo Square session cookie + future
# session-cookie surfaces. ≥ 32 bytes recommended.
SESSION_SECRET=dev-session-secret

# ─── Production gate (T-I) ───

# ENV — set to "production" to enable fail-closed mode on env-var
# absence: VALIDATOR_SECRET, LNURL_JWT_SECRET, LNURL_STUB, LNURL_SCHEME
# all become fatal-on-misconfig instead of warn-with-fallback. Leave
# empty in dev.
ENV=

# ─── Optional with defaults ───

LOG_LEVEL=info
PORT=8080
PUBLIC_URL=
DEV_CONSOLE=1   # any non-empty value enables /devops legacy console

# ─── Square OAuth (demo surface) ───

SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_REDIRECT_URI=http://localhost:8080/auth/square/callback
SQUARE_ENVIRONMENT=sandbox     # sandbox | production
CANARY_ENCRYPTION_KEY=         # 32-byte hex; if set, Square refresh tokens are AES-encrypted at rest

# ─── Identity / JWT (consumed by AtlasView contract per GRO-848) ───

IDENTITY_JWKS_URL=
IDENTITY_JWKS_CACHE_TTL_SECONDS=3600
IDENTITY_JWT_AUDIENCE=
IDENTITY_JWT_ISSUER=

# ─── Secret backend ───

SECRET_BACKEND=pgx                  # pgx (dev plaintext) | sm (GCP Secret Manager)
SECRET_BACKEND_REQUIRE_SM=          # set to "1" to fatal if SECRET_BACKEND=sm fails to construct (production)
GCP_PROJECT_ID=                     # required when SECRET_BACKEND=sm

# ─── Protocol layer (L402 + LNURL — patent 63/991,596) ───

VALIDATOR_SECRET=                   # 64-char hex (32 bytes). Required in production.
VALIDATOR_SATOSHI_PRICE=100         # satoshis charged per proof verification
LNURL_JWT_SECRET=                   # 64-char hex (32 bytes). Required in production.
LNURL_STUB=true                     # "true" skips secp256k1 verification (dev/CI only — fatal in production)
LNURL_SCHEME=http                   # "http" for local dev; production fatals if not "https"
LNURL_HOST=localhost:8080
ORDINALSBOT_API_KEY=                # set to use real Bitcoin signet inscriber; absent = stub mode

# ─── Sub3 anchor / Merkle root ───
# (No env vars on the gateway side; sub3 binary reads its own.)

# ─── Manifest pipeline (GRO-836 / GRO-849) ───

MANIFEST_ROUTEWALK=                 # "1" dumps build/routes-seen.json at boot. Off in production.
MANIFEST_ROUTEWALK_OUT=             # override default build path

# ─── Observability ───

OTEL_SERVICE_NAME=canary-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SAMPLE_RATE=0.1

# ─── LangGraph (release approval surface — DEV_CONSOLE-gated) ───

LANGGRAPH_URL=http://localhost:2024

# ─── Test-only ───
# These are read by integration tests under //go:build integration.
# Bare go test ./... should never need them.

TEST_DATABASE_URL=postgres://growdirect:growdirect_dev@localhost:5432/canary_gcp_test?sslmode=disable
GATEWAY_TEST_DATABASE_URL=postgres://growdirect:growdirect_dev@localhost:5432/canary_gcp_test?sslmode=disable
GATEWAY_TEST_VALKEY_URL=redis://:valkey_dev@localhost:6379/3
